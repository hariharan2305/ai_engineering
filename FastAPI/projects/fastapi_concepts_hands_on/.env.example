SUPABASE_SECRET_KEY=YOUR_SERVICE_KEY_HERE

# ── Redis (local development) ─────────────────────────────────────────────────
# Start local Redis: docker run -d -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379

# ── Upstash Redis (Exercise 8 — serverless production) ───────────────────────
# Sign up free at https://upstash.com → Create Database → REST API tab
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
