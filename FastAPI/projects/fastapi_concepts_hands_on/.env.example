# ── Supabase API ──────────────────────────────────────────────────────────────
# Project URL
SUPABASE_URL=https://wvjyeshrqnrevpmgfhqa.supabase.co

# Anon key — safe for client-side use, respects RLS
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Ind2anllc2hycW5yZXZwbWdmaHFhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIzMzQ3NDksImV4cCI6MjA4NzkxMDc0OX0.91ql1p79Tsm8g7dY9EpGXtHHbgkkIlhRkz9LhVrB0-A

